```gitignore
# ------------------------------------------------------------
# Hank's Junk Drawer of Random Pages
# Static GitHub Pages project
# macOS + Linux development
# ------------------------------------------------------------


# ------------------------------------------------------------
# macOS system files
# ------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride

# Icon files generated by macOS Finder
Icon?

# macOS metadata/resource forks
._*

# macOS volume metadata
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes


# ------------------------------------------------------------
# Linux system files
# ------------------------------------------------------------
*~

# KDE / Dolphin metadata
.directory

# Trash folders
.Trash-*
.trash-*

# NFS temporary files
.nfs*


# ------------------------------------------------------------
# Editor / IDE files
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.swn
*.bak
*.tmp
*.temp

# Vim session files
Session.vim
Sessionx.vim

# Emacs
\#*\#
.\#*


# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# ------------------------------------------------------------
# Node / tooling artifacts
# Helpful if you later add build tools, linters, or formatters
# ------------------------------------------------------------
node_modules/
dist/
build/
.cache/
.parcel-cache/
.vite/
.next/
.nuxt/
.svelte-kit/

package-lock.json
yarn.lock
pnpm-lock.yaml


# ------------------------------------------------------------
# Python artifacts
# Helpful if you use local scripts for image conversion,
# favicon generation, or repo utilities
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

.venv/
venv/
env/
ENV/

.pytest_cache/
.mypy_cache/
.ruff_cache/


# ------------------------------------------------------------
# Local environment / secrets
# ------------------------------------------------------------
.env
.env.*
!.env.example

*.local


# ------------------------------------------------------------
# Generated image / favicon work files
# Keep final favicon assets committed, ignore scratch exports
# ------------------------------------------------------------
*.psd
*.xcf
*.afdesign
*.sketch

favicon-work/
scratch/
tmp/
temp/


# ------------------------------------------------------------
# Archives / packaged exports
# ------------------------------------------------------------
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z


# ------------------------------------------------------------
# Do NOT ignore normal GitHub Pages files
# ------------------------------------------------------------
!index.html
!README.md
!favicon.ico
!assets/
!assets/**
!junk-drawer.json
```

